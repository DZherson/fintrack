# ─── Base de datos ────────────────────────────────────────────────────────────
# URL de conexión a PostgreSQL (Supabase: Project Settings → Database → URI)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ─── NextAuth.js ──────────────────────────────────────────────────────────────
# Secreto para firmar los tokens JWT (genera uno con: openssl rand -base64 32)
AUTH_SECRET="your-secret-here-replace-in-production"

# URL base de la aplicación (en local: http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Crea credenciales en: console.cloud.google.com → APIs → Credentials
# URI de redirección autorizada: {NEXTAUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"
